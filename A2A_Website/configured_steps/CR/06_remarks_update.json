{
  "step": "remarks_update",
  "conditions": {
    "rules": [
      {
        "target_value": "Supplier Paid",
        "conditions": [
          {
            "column": "Remarks",
            "operator": "is_blank",
            "values": []
          },
          {
            "column": "Inco Term",
            "operator": "not_contains",
            "values": [
              "EXW"
            ]
          },
          {
            "column": "Inco Term",
            "operator": "not_starts_with",
            "values": [
              "F"
            ]
          },
          {
            "column": "Consignor Name",
            "operator": "not_contains",
            "values": [
              "INTEL"
            ]
          }
        ]
      }
    ]
  }
}